# Variáveis de ambiente para a API TCC (opcional)
# Renomeie para .env e configure conforme necessário
# Em produção, use getenv() no settings.php

DB_DRIVER=sqlite
SQLITE_PATH=api/database/data/nexora.sqlite

# Se quiser usar MySQL:
# DB_DRIVER=mysql
# DB_NAME=tcc_db
# DB_HOST=127.0.0.1
# DB_USER=root
# DB_PASS=
# DB_PORT=3306

# JWT — defina um segredo forte em produção
JWT_SECRET=altere-este-segredo-em-producao
JWT_TTL_SECONDS=86400

# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
# AI_REPORT_MAX_ROWS=500
# Em WAMP/dev, SSL pode falhar sem CA bundle. DEBUG_MODE já desativa verificação.
# Force verificação em dev: OPENROUTER_SSL_VERIFY=1
# Force desativar (não recomendado em produção): OPENROUTER_SSL_VERIFY=0

# Recuperação de senha (e-mail). Sem MAIL_SMTP_HOST a API tenta mail() do PHP.
# Em desenvolvimento, se o envio falhar, o link pode ser gravado em api/database/data/password_reset_debug.log (DEBUG_MODE).
# FRONTEND_PUBLIC_URL=http://localhost:5173
# MAIL_SMTP_HOST=smtp.gmail.com
# MAIL_SMTP_PORT=587
# MAIL_SMTP_USER=seu@gmail.com
# MAIL_SMTP_PASS=sua_senha_de_app
# MAIL_SMTP_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=noreply@suaempresa.com
# MAIL_FROM_NAME=NeXora
